# ============================================================
# SERVER
# ============================================================
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
API_VERSION=v1

# ============================================================
# DATABASE (MySQL)
# ============================================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=exam_saas_user
DB_PASSWORD=change_me
DB_NAME=exam_saas
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
DB_CONNECT_TIMEOUT_MS=10000

# ============================================================
# AUTH (reserved for Task 4 - not used yet)
# ============================================================
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRY=7d
BCRYPT_SALT_ROUNDS=12

# ============================================================
# CLAUDE API (reserved for later task - not used yet)
# ============================================================
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=4096
CLAUDE_LEGIBILITY_THRESHOLD=0.75

# ============================================================
# FILE UPLOAD (reserved for later task - not used yet)
# ============================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ============================================================
# RATE LIMITING (reserved for later task - not used yet)
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=debug
LOG_DIR=./logs

# ============================================================
# BACKGROUND WORKER
# ============================================================
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_MS=5000
WORKER_BATCH_SIZE=5
